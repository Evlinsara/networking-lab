#include<stdio.h>
#include<stdlib.h>

int main(){
    int seq=1, ack, errf, erra;

    while(seq<=5){
        printf("SENDER: sent packet with seq NO:%d\n",seq);

        errf=rand()%4;
        if(errf==0){
            printf("Error While sending Packet\n");
            continue;
        }

        printf("\nRECEIVER: Received packet with seq %d\n\n",seq);

        erra=rand()%4;
        if(erra==0){
            printf("Error While sending ACK\n");
            printf("SENDER: sent packet with seq NO:%d\n\n",seq);
            printf("RECEIVER: Duplicated packet with seq %d\n\n",seq);
        }

        ack=seq;
        printf("SENDER: Received ACK for packet %d\n",ack);
        seq++;
    }
}
